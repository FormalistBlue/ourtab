{
  "name": "ourtab",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "dev": "nuxt dev",
    "build": "nuxt build",
    "preview": "nuxt preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "deploy": "nuxt build && sudo systemctl restart ourtab && echo 'Deployed OK'",
    "deploy:status": "sudo systemctl status ourtab --no-pager -l",
    "deploy:logs": "sudo journalctl -u ourtab -f"
  },
  "dependencies": {
    "@imengyu/vue3-context-menu": "^1.4.0",
    "@lucide/vue": "^1.21.0",
    "@nuxtjs/i18n": "^9.5.6",
    "@pinia/nuxt": "^0.5.5",
    "@tailwindcss/vite": "^4.3.1",
    "@vueuse/core": "^14.3.0",
    "@vueuse/nuxt": "^10.11.1",
    "better-sqlite3": "^11.8.1",
    "drizzle-orm": "^0.39.3",
    "gsap": "^3.12.7",
    "naive-ui": "^2.44.1",
    "nuxt": "^3.17.7",
    "nuxtjs-naive-ui": "^1.0.2",
    "pinia": "^2.3.1",
    "unplugin-auto-import": "^21.0.0",
    "unplugin-vue-components": "^32.1.0",
    "uuid": "^11.1.0",
    "vue": "^3.5.13",
    "vue-draggable-plus": "^0.6.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@nuxt/test-utils": "^3.15.4",
    "@tailwindcss/postcss": "^4.3.1",
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.10.7",
    "@vitejs/plugin-vue": "^5.2.1",
    "@vue/test-utils": "^2.4.6",
    "autoprefixer": "^10.5.0",
    "drizzle-kit": "^0.30.4",
    "eslint": "^9.18.0",
    "happy-dom": "^16.7.2",
    "postcss": "^8.5.15",
    "tailwindcss": "^4.3.1",
    "typescript": "^5.7.3",
    "vite": "^6.0.7",
    "vitest": "^3.2.4",
    "vue-tsc": "^2.2.0"
  }
}
